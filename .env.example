# Copy this file to .env and fill in any values needed for your environment.
# Phase 1 only requires the database URL; AWS credentials are needed from
# Phase 3 onward (when we wire Bedrock into the actual chat path).

# --- Application ---
ENVIRONMENT=local
LOG_LEVEL=INFO

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=postgresql+psycopg://eka:eka@db:5432/eka

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173"]

# --- AWS / Bedrock ---
# Used by `make smoke` and (later) by the API + ingestion worker.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Bedrock model IDs. Override if you have access to different models.
BEDROCK_TEXT_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# --- Chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# --- Embeddings ---
# "local"   -> free, on-CPU via fastembed + BAAI/bge-large-en-v1.5
# "bedrock" -> Titan v2 via AWS (small per-token cost; needs AWS creds)
EMBEDDING_PROVIDER=local
EMBEDDING_LOCAL_MODEL=BAAI/bge-large-en-v1.5

# --- Object storage (S3 / MinIO) ---
# Local dev: docker-compose.yml injects S3_ENDPOINT_URL/keys to point at MinIO.
# Production: leave S3_ENDPOINT_URL empty so boto3 uses real AWS S3, and
# leave the keys empty so boto3 uses the standard AWS credential chain.
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET=eka-documents
